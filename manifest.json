{
  "name": "ScoutBrief",
  "version": "1.0.0",
  "description": "Reference implementation of the Hedera Agent Kit V4 Hooks & Policies pattern: spend caps, counterparty allowlists, contextual approval, and HCS-2 audit applied to a demo agent that buys real third-party APIs in HBAR. Fork the pattern for multi-tenant SaaS budget governance, regulated agent workflows, or A2A marketplaces.",
  "author": { "name": "Nicolas", "github": "Nicolas6879" },
  "endpoints": {
    "demo": "https://scoutbrief.vercel.app",
    "api": "https://scoutbrief.fly.dev",
    "console": "https://scoutbrief.vercel.app/console",
    "manifest": "https://scoutbrief.fly.dev/manifest"
  },
  "hederaAgentKit": { "version": "4.x", "language": "javascript" },
  "policies": {
    "manifestTopicId": "TBD",
    "auditTopicId": "TBD",
    "hooks": ["auditLogHook", "settlementHook"],
    "policies": [
      "counterpartyAllowlistPolicy",
      "spendLimitPolicy",
      "contextualApprovalPolicy"
    ],
    "briefCategoriesCovered": ["spend_limits", "counterparties", "contextual_approval"]
  },
  "payments": {
    "currencies": ["HBAR"],
    "network": "hedera-testnet",
    "x402Facilitator": "https://scoutbrief.fly.dev/x402"
  },
  "thirdPartyServices": [
    {
      "name": "Tavily",
      "endpoint": "https://api.tavily.com/search",
      "purpose": "web research"
    },
    {
      "name": "Resend",
      "endpoint": "https://api.resend.com/emails",
      "purpose": "email delivery"
    }
  ],
  "llm": {
    "primary": "Groq Llama 3.1 70b",
    "fallback": "Google Gemini 2.0 Flash"
  },
  "category": "reference-implementation",
  "indexable": true,
  "openSourced": true,
  "license": "MIT",
  "repository": "https://github.com/Nicolas6879/ScoutBrief"
}
