# =============================================================================
# Hedera testnet credentials
# =============================================================================
# Get from https://portal.hedera.com (create ED25519 account)
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.XXXXX
HEDERA_OPERATOR_KEY=302e020100300506032b657004220420...  # DER encoded private key

# Created programmatically by scripts/setup-testnet.ts
HEDERA_ESCROW_ID=0.0.XXXXX
HEDERA_ESCROW_KEY=302e020100300506032b657004220420...    # DER encoded escrow private key

# HCS-2 topics (created by scripts/setup-testnet.ts)
HCS_POLICY_MANIFEST_TOPIC=0.0.XXXXX
HCS_AUDIT_TOPIC=0.0.XXXXX

# Mirror Node (testnet REST endpoint)
MIRROR_NODE_REST=https://testnet.mirrornode.hedera.com/api/v1

# =============================================================================
# LLM providers (free tiers)
# =============================================================================
# Groq: https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Google AI Studio: https://aistudio.google.com
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash-lite

# =============================================================================
# Third-party services (free tiers)
# =============================================================================
# Tavily: https://tavily.com
TAVILY_API_KEY=tvly-...

# Resend: https://resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@your-verified-domain.com  # or onboarding@resend.dev
RESEND_WEBHOOK_SECRET=whsec_...

# Set RESEND_VERIFIED_DOMAIN=true once a custom domain is verified on Resend
# (otherwise free tier only delivers to OWNER_EMAIL). When false, email is
# skipped for non-owner recipients and the brief is shown inline only.
RESEND_VERIFIED_DOMAIN=false
OWNER_EMAIL=your-resend-account@example.com

# =============================================================================
# Endpoint hashes (pre-computed sha256 of API URLs for counterpartyAllowlistPolicy)
# Run: node scripts/compute-endpoint-hashes.ts to generate
# =============================================================================
TAVILY_ENDPOINT_HASH=
RESEND_ENDPOINT_HASH=
GROQ_ENDPOINT_HASH=
GEMINI_ENDPOINT_HASH=

# =============================================================================
# Frontend / hosting
# =============================================================================
NEXT_PUBLIC_AGENT_API_URL=http://localhost:3001
NEXT_PUBLIC_HASHSCAN_BASE=https://hashscan.io/testnet

# hCaptcha (anti-DoS)
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET=

# =============================================================================
# Policy config (caps in tinybars; 1 HBAR = 100_000_000 tinybars)
# =============================================================================
PER_BRIEF_CAP_TINYBARS=50000000      # 0.5 HBAR
DAILY_CAP_TINYBARS=1000000000        # 10 HBAR
PER_RECIPIENT_DAILY_LIMIT=30
SETTLEMENT_HOLD_MINUTES=10

# =============================================================================
# Server
# =============================================================================
AGENT_PORT=3001
FACILITATOR_PORT=3002
NODE_ENV=development
