# ScoutBrief console (Next.js) — environment

# Public base URL of the deployed agent API (Express server in apps/agent).
# Local dev: http://localhost:3001
# Production: the URL where you host the agent (e.g. https://scoutbrief.fly.dev)
# NOTE: this is a NEXT_PUBLIC_ var — inlined at BUILD time, so it must be set
# in Vercel's Environment Variables before the build runs.
NEXT_PUBLIC_AGENT_API_URL=http://localhost:3001

# HashScan explorer base for the "view receipt / audit" links.
NEXT_PUBLIC_HASHSCAN_BASE=https://hashscan.io/testnet
